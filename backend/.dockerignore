# ─── Secrets — NEVER in Docker image ─────────────────────────────────────────
.env
.env.*
*.env

# ─── Python artifacts ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
env/
*.egg-info/
dist/
build/
.eggs/

# ─── Dev / test artifacts ─────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
tests/

# ─── IDE / OS ─────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ─── Git ──────────────────────────────────────────────────────────────────────
.git/
.gitignore

# ─── Docs (not needed at runtime) ─────────────────────────────────────────────
README.md
*.md
