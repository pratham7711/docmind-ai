# ─── DocMind AI — Backend Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Database (Supabase) ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must match NEXTAUTH_SECRET in the Next.js frontend
JWT_SECRET=generate-with: python3 -c "import secrets; print(secrets.token_hex(32))"

# ─── Gemini (chat model) ──────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ─── Pinecone (integrated embedding — multilingual-e5-large, 1024-dim) ────────
# Get from: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_HOST=https://your-index-host.svc.pinecone.io
PINECONE_INDEX_NAME=docmind
PINECONE_EMBEDDING_MODEL=multilingual-e5-large
PINECONE_DIMENSIONS=1024

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → REST API tab
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
